.DS_Store
**/.DS_Store
scripts/.env.local
**/*.lpk
**/*.pyc
**/.lzc-cli-build*/
artifacts/
dist/
# registry/* — most contents are run-scoped artifacts (logs, codex tasks,
# Discord queues, browser screenshots). The ! re-includes below pin the
# canonical state files that workflows commit back to template so the next
# cycle picks up where the previous one left off.
registry/candidates/*
!registry/candidates/latest.json
!registry/candidates/local-agent-latest.json
registry/status/*
!registry/status/local-publication-status.json
!registry/status/developer-apps.json
registry/auto-migration/*
!registry/auto-migration/exclude-list.json
!registry/auto-migration/queue.json
!registry/auto-migration/ai-reviews.jsonl
apps/*/upstream/
apps/*/.browser-acceptance-plan.json
apps/*/.functional-check.json
apps/*/acceptance/
.acc/sessions/
.acc/bundles/
.acc/archive/
optimize_full_migration_test/
optimize_full_migration/

# Claude Code per-developer settings (tokens, local permissions, env vars).
# Each developer keeps their own copy; never commit.
.claude/settings.local.json
