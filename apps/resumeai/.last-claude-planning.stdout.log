nnection — points to the co-located mongo sidecar\n      - MONGODB_URL=mongodb://mongo:27017/resumeai\n      # Set to the public HTTPS URL of this app after installation\n      - BASE_URL=\n      - NODE_ENV=production\n    healthcheck:\n      test:\n        - CMD-SHELL\n        - wget -qO /dev/null http://localhost:3000/ || exit 1\n      interval: 30s\n      timeout: 10s\n      retries: 5\n\n  mongo:\n    image: mongo:7\n    binds:\n      - /lzcapp/var/db/resumeai/mongo:/data/db\n    healthcheck:\n      test:\n        - CMD-SHELL\n        - mongosh --eval \"db.adminCommand('ping')\" --quiet || exit 1\n      interval: 10s\n      timeout: 5s\n      retries: 5\n","structuredPatch":[],"originalFile":null,"userModified":false}}
