{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_017s18CyucyPpAK2TWJNzEjK","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XYiPHJMyQHU5D6LfEM2ZV2","name":"Write","input":{"file_path":"/__w/lzcat-apps/lzcat-apps/apps/resumeai/lzc-manifest.yml","content":"lzc-sdk-version: '0.1'\npackage: fun.selfstudio.app.migration.resumeai\nversion: 1.0.0\nname: ResumeAI\ndescription: Generate ATS-friendly resumes quickly using AI for tailored content, keyword optimization, and real-time editing with customizable templates.\nlicense: MIT\nhomepage: https://github.com/Doomish77/ResumeAI\nauthor: Doomish77\n\napplication:\n  subdomain: resumeai\n  upstreams:\n    - location: /\n      backend: http://web:3000/\n  injects:\n    - builtin://simple-inject-password\n\nlocales:\n  en:\n    name: ResumeAI\n    description: Build ATS-friendly resumes fast with AI-powered content suggestions, real-time editing, and customizable templates.\n  zh:\n    name: ResumeAI\n    description: 使用 AI 快速生成 ATS 友好的简历，支持智能内容建议、实时编辑和可定制模板。\n\nservices:\n  web:\n    image: registry.lazycat.cloud/placeholder/resumeai:bootstrap\n    depends_on:\n      - mongo\n    environment:\n      # Clerk auth — requires a Clerk application at https://clerk.com\n      # NEXT_PUBLIC_ vars are read by Next.js App Router server components at runtime.\n      - NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY={{ index .U \"clerk_publishable_key\" }}\n      - CLERK_SECRET_KEY={{ index .U \"clerk_secret_key\" }}\n      - NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in\n      - NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up\n      # Google Gemini API key for AI resume suggestions\n      - GEMINI_API_KEY={{ index .U \"gemini_api_key\" }}\n      # MongoDB connection — points to the co-located mongo sidecar\n      - MONGODB_URL=mongodb://mongo:27017/resumeai\n      # Set to the public HTTPS URL of this app after installation\n      - BASE_URL=\n      - NODE_ENV=production\n    healthcheck:\n      test:\n        - CMD-SHELL\n        - wget -qO /dev/null http://localhost:3000/ || exit 1\n      interval: 30s\n      timeout: 10s\n      retries: 5\n\n  mongo:\n    image: mongo:7\n    binds:\n      - /lzcapp/var/db/resumeai/mongo:/data/db\n    healthcheck:\n      test:\n        - CMD-SHELL\n        - mongosh --eval \"db.adminCommand('ping')\" --quiet || exit 1\n      interval: 10s\n      timeout: 5s\n      retries: 5\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":381,"cache_read_input_tokens":87473,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":381},"output_tokens":72,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8885b858-35f1-4392-9afa-5fc75e8538ec","uuid":"36e968c0-3eef-40b2-9afa-0ff55a925b27"}
