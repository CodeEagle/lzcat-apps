        {
          "location": "/_lzc_probe",
          "backend": "http://markitdown:3000/healthz"
        }
      ]
    },
    "services": {
      "markitdown": {
        "image": "registry.lazycat.cloud/invokerlaw/codeeagle/markitdown:e2e1ab9581a4fb75",
        "command": "all",
        "environment": [
          "MARKITDOWN_ENABLE_PLUGINS=true",
          "MARKITDOWN_MAX_UPLOAD_BYTES=26214400"
