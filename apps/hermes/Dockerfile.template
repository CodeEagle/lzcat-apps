# syntax=docker/dockerfile:1.6
# =============================================================================
# Hermes single-image build — nginx + manager + webui under supervisord
# Modified for LazyCat: clone repos during build instead of COPY from context
# =============================================================================
FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HERMES_HOME=/data \
    HERMES_WEBUI_AGENT_DIR=/opt/hermes-agent \
    PATH=/data/bin:/root/.local/bin:/usr/local/bin:/usr/local/sbin:/usr/sbin:/usr/bin:/sbin:/bin

# System deps: nginx, supervisord, git (for git pull updates), curl, rsync
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    curl \
    git \
    nginx \
    rsync \
    supervisor \
    tini \
    && rm -rf /var/lib/apt/lists/* \
    && rm -f /etc/nginx/conf.d/default.conf /etc/nginx/sites-enabled/default

# -----------------------------------------------------------------------------
# Clone application sources (replaces COPY repos/ from build context)
# -----------------------------------------------------------------------------
RUN git clone --depth 1 https://github.com/NousResearch/hermes-agent.git /opt/hermes-agent
RUN git clone --depth 1 https://github.com/nesquena/hermes-webui.git /app/webui

# hermes-manager — clone full CodeEagle/hermes repo as a git working tree
# at /opt/hermes so the manager's own code (including the terminal UI under
# manager/widget/ and manager/api/explorer.py) can be hot-updated at runtime
# via WATCHED_REPOS=CodeEagle/hermes. /app/manager is kept as a symlink for
# the supervisord command path.
RUN git clone --depth 1 https://github.com/CodeEagle/hermes.git /opt/hermes && \
    ln -s /opt/hermes/manager /app/manager

# Canonical .env.example (seeded into /data/.env on first run by entrypoint)
COPY .env.example /app/.env.example

# Patch upstream bugs, then mark patched files --skip-worktree so git_pull's
# dirty-tree guard still fast-forwards at hot-update time:
# 1. browser_tool.py: handle BROWSER_INACTIVITY_TIMEOUT="" (empty env var injected by LazyCat)
# 2. .env.example: set sensible defaults so seeded /data/.env has valid values
# 3. float-ball.js switchUI: unregister webui service workers + clear caches
#    before and after switching, then navigate to "/" with a cache-buster.
#    Also drop the "Check Updates" menu entry — hermes-agent and hermes-webui
#    have their own self-update mechanisms; the manager-driven git-pull flow
#    is redundant.
# 4. explorer.py: replace TERM=wterm (unknown to terminfo) with xterm-256color.
# 5. main.py + updates.py: disable the manager-side updates router entirely.
RUN sed -i 's/int(os\.environ\.get("BROWSER_INACTIVITY_TIMEOUT", "300"))/int(os.environ.get("BROWSER_INACTIVITY_TIMEOUT") or "300")/g' \
        /opt/hermes-agent/tools/browser_tool.py && \
    git -C /opt/hermes-agent update-index --skip-worktree tools/browser_tool.py && \
    sed -i 's/^BROWSER_INACTIVITY_TIMEOUT=$/BROWSER_INACTIVITY_TIMEOUT=120/' /app/.env.example && \
    sed -i 's/^BROWSER_SESSION_TIMEOUT=$/BROWSER_SESSION_TIMEOUT=300/' /app/.env.example && \
    sed -i 's|"TERM": "wterm"|"TERM": "xterm-256color"|' \
        /opt/hermes/manager/api/explorer.py

RUN python3 <<'PY'
from pathlib import Path

# float-ball.js: rewrite switchUI with cache clearing + drop "Check Updates" menu item
path = Path("/opt/hermes/manager/widget/float-ball.js")
text = path.read_text()

start = text.index("  async function switchUI() {")
end = text.index("  async function resetConfig()", start)
replacement = r'''  async function clearWebUICaches() {
    try {
      if (navigator.serviceWorker) {
        var regs = await navigator.serviceWorker.getRegistrations();
        await Promise.all(regs.map(function (r) { return r.unregister(); }));
      }
      if (window.caches) {
        var keys = await caches.keys();
        await Promise.all(keys.map(function (k) { return caches.delete(k); }));
      }
    } catch (e) {}
  }

  async function switchUI() {
    var idx = UI_CYCLE.indexOf(state.activeUI);
    var target = UI_CYCLE[(idx + 1) % UI_CYCLE.length];
    try {
      await clearWebUICaches();
      var resp = await fetch(API + "/ui/switch", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        cache: "no-store",
        body: JSON.stringify({ target: target }),
      });
      if (!resp.ok) {
        var err = await resp.json().catch(function () { return {}; });
        throw new Error(err.detail || ("HTTP " + resp.status));
      }
      await clearWebUICaches();
      setTimeout(function () {
        location.replace("/?hm_ui=" + encodeURIComponent(target) + "&hm_ts=" + Date.now());
      }, 500);
    } catch (e) {
      alert("Switch failed: " + e.message);
    }
  }

'''
text = text[:start] + replacement + text[end:]

menu_old = (
    "      '<button class=\"hm-menu-item\" data-action=\"updates\">',\n"
    "      '  <span class=\"hm-icon\">&#128260;</span> Check Updates',\n"
    "      '</button>',\n"
)
if menu_old not in text:
    raise SystemExit("float-ball.js updates menu anchor not found")
text = text.replace(menu_old, "")

path.write_text(text)

# main.py: drop updates_router import + include
main_path = Path("/opt/hermes/manager/main.py")
main_text = main_path.read_text()
for snippet in (
    "from api.updates import router as updates_router\n",
    "app.include_router(updates_router, prefix=\"/api/manager\")\n",
):
    if snippet not in main_text:
        raise SystemExit("main.py anchor not found: " + repr(snippet))
    main_text = main_text.replace(snippet, "")
main_path.write_text(main_text)
PY

RUN git -C /opt/hermes update-index --skip-worktree \
        manager/widget/float-ball.js \
        manager/api/explorer.py \
        manager/main.py

# -----------------------------------------------------------------------------
# Python dependencies (single venv via system pip)
# -----------------------------------------------------------------------------
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -e /opt/hermes-agent && \
    pip install --no-cache-dir -r /app/webui/requirements.txt && \
    pip install --no-cache-dir -r /app/manager/requirements.txt

# -----------------------------------------------------------------------------
# Nginx + supervisord + entrypoint
# -----------------------------------------------------------------------------
COPY nginx/nginx.conf /etc/nginx/nginx.conf
COPY supervisord.conf /etc/supervisor/supervisord.conf
COPY entrypoint.sh /entrypoint.sh
RUN python3 <<'PY'
from pathlib import Path

path = Path("/entrypoint.sh")
text = path.read_text()
old = 'mkdir -p "${DATA_DIR}" "${DATA_DIR}/manager" "${DATA_DIR}/webui" "${DATA_DIR}/workspace" "${NGINX_CONF_DIR}"'
new = r'''mkdir -p "${DATA_DIR}" "${DATA_DIR}/manager" "${DATA_DIR}/webui" "${DATA_DIR}/workspace" "${DATA_DIR}/bin" "${DATA_DIR}/.local/bin" "${NGINX_CONF_DIR}"

# Persist user-installed CLI tools across container recreations. Keep ~/.local
# as the user-facing path for tools such as Claude Code, but store it on /data.
if [ ! -e /root/.local ]; then
  ln -s "${DATA_DIR}/.local" /root/.local
elif [ -d /root/.local ] && [ ! -L /root/.local ]; then
  rsync -a /root/.local/ "${DATA_DIR}/.local/" || true
  rm -rf /root/.local
  ln -s "${DATA_DIR}/.local" /root/.local
fi
if [ ! -e /usr/local/bin/copilot ] && [ ! -L /usr/local/bin/copilot ]; then
  ln -s "${DATA_DIR}/bin/copilot" /usr/local/bin/copilot
elif [ -f /usr/local/bin/copilot ] && [ ! -f "${DATA_DIR}/bin/copilot" ]; then
  cp /usr/local/bin/copilot "${DATA_DIR}/bin/copilot" || true
fi

cat > "${DATA_DIR}/shell-path.sh" <<'EOF'
export PATH="/data/bin:$HOME/.local/bin:$PATH"
EOF
for rc in /root/.profile /root/.bashrc /root/.zshrc; do
  if [ ! -e "$rc" ]; then
    ln -s "${DATA_DIR}/shell-path.sh" "$rc"
  elif ! grep -q '/data/shell-path.sh' "$rc" 2>/dev/null; then
    printf '\n[ -f /data/shell-path.sh ] && . /data/shell-path.sh\n' >> "$rc"
  fi
done
export PATH="/data/bin:/root/.local/bin:${PATH}"'''
if old not in text:
    raise SystemExit("entrypoint mkdir anchor not found")
path.write_text(text.replace(old, new))
PY

RUN chmod +x /entrypoint.sh && \
    mkdir -p /etc/nginx/conf.d /var/log/supervisor /data

EXPOSE 80

HEALTHCHECK --interval=15s --timeout=5s --retries=3 --start-period=60s \
    CMD curl -fsS http://127.0.0.1/api/manager/status > /dev/null || exit 1

ENTRYPOINT ["/usr/bin/tini", "--", "/entrypoint.sh"]
