    "project_name": "mercury-agent",
    "description": "Mercury Agent",
    "description_zh": "灵魂驱动的 AI agent，懒猫微服 web 终端封装版",
    "homepage": "https://mercury.cosmicstack.org/",
    "license": "MIT",
