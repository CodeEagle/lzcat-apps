    "dockerfile_type": "custom",
    "build_context": ".",
    "docker_platform": "linux/amd64",
    "image_targets": [
      "mercury-agent"
    ],
    "service_builds": [
      {
        "target_service": "mercury-agent",
        "build_strategy": "target_repo_dockerfile",
        "dockerfile_path": "Dockerfile",
        "build_context": ".",
        "build_args": {},
        "image_name": "mercury-agent-lzcat"
      }
    ],
    "service_port": 80,
    "services": {
      "mercury-agent": {
        "image": "registry.lazycat.cloud/placeholder/mercury-agent:mercury-agent",
        "environment": [
          "MERCURY_HOME=/data",
          "DEFAULT_PROVIDER=deepseek",
          "HEARTBEAT_INTERVAL_MINUTES=60",
          "DAILY_TOKEN_BUDGET=50000"
        ],
        "binds": [
          "/lzcapp/var/data/mercury-agent:/data",
          "/lzcapp/var/data/mercury-agent/workspace:/root/workspace"
        ]
      }
    },
    "application": {
      "subdomain": "mercury-agent",
      "public_path": [
        "/"
      ],
      "upstreams": [
        {
          "location": "/",
          "backend": "http://mercury-agent:80/"
        }
      ]
    },
    "data_paths": [
      {
        "host": "/lzcapp/var/data/mercury-agent",
        "container": "/data",
        "description": "MERCURY_HOME — config / memory / .env"
      },
      {
        "host": "/lzcapp/var/data/mercury-agent/workspace",
        "container": "/root/workspace",
        "description": "Workspace area for explorer"
      }
    ],
    "startup_notes": [
      "上游为 npm CLI（@cosmicstack/mercury-agent），通过 npm registry 安装",
      "单容器：nginx + supervisord + ttyd + mercury CLI（无 Python / FastAPI）",
      "默认入口 = Web 终端（ttyd），自动启动 mercury，CLI 退出后落到 bash --login",
      "floatball 通过 nginx sub_filter 注入到 ttyd 主页，仅保留 File Explorer 一项",
      "File Explorer 为纯静态页 + nginx autoindex JSON + alias 直读文件",
