        "setup_script": "mkdir -p /var/www/html/content /var/www/html/cache /var/www/html/config /var/www/html/config/users\ncp -an /opt/htmly-dist/content/. /var/www/html/content/ 2>/dev/null || true\ncp -an /opt/htmly-dist/cache/. /var/www/html/cache/ 2>/dev/null || true\ncp -an /opt/htmly-dist/config/. /var/www/html/config/ 2>/dev/null || true\nprintf 'ok\\n' > /var/www/html/lazycat-health.html\nchown -R www-data:www-data /var/www/html/content /var/www/html/cache /var/www/html/config\n",
        "healthcheck": {
          "test": [
            "CMD-SHELL",
            "curl -fsS http://127.0.0.1/lazycat-health.html >/dev/null || exit 1"
          ],
          "interval": "10s",
          "timeout": "5s",
          "retries": 6,
          "start_period": "60s"
