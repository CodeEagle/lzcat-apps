{
  "managed_by": "full_migrate",
  "generated_from_upstream": "multica-ai/multica",
  "fixes": {
    "project_name": "multica",
    "description": "The open-source managed agents platform",
    "homepage": "https://multica.ai",
    "author": "multica-ai",
    "build_strategy": "upstream_dockerfile",
    "docker_platform": "linux/amd64",
    "image_targets": [
      "frontend",
      "backend"
    ],
    "dependencies": [
      {
        "target_service": "postgres",
        "source_image": "pgvector/pgvector:pg17"
      }
    ],
    "service_builds": [
      {
        "target_service": "backend",
        "build_strategy": "upstream_dockerfile",
        "source_dockerfile_path": "Dockerfile",
        "build_context": ".",
        "build_args": {},
        "image_name": "multica-backend"
      },
      {
        "target_service": "frontend",
        "build_strategy": "upstream_dockerfile",
        "source_dockerfile_path": "Dockerfile.web",
        "build_context": ".",
        "build_args": {
          "REMOTE_API_URL": "http://backend:8080"
        },
        "image_name": "multica-frontend"
      }
    ],
    "service_port": 3000,
    "services": {
      "postgres": {
        "image": "registry.lazycat.cloud/placeholder/multica:postgres",
        "environment": [
          "POSTGRES_DB=multica",
          "POSTGRES_USER=multica",
          "POSTGRES_PASSWORD=multica"
        ],
        "binds": [
          "/lzcapp/var/db/multica/postgres:/var/lib/postgresql/data"
        ],
        "healthcheck": {
          "test": [
            "CMD-SHELL",
            "pg_isready -U ${POSTGRES_USER:-multica} -d ${POSTGRES_DB:-multica}"
          ],
          "interval": "5s",
          "timeout": "5s",
          "retries": 5
        }
      },
      "backend": {
        "image": "registry.lazycat.cloud/placeholder/multica:backend",
        "environment": [
          "DATABASE_URL=postgres://${POSTGRES_USER:-multica}:${POSTGRES_PASSWORD:-multica}@postgres:5432/${POSTGRES_DB:-multica}?sslmode=disable",
          "PORT=8080",
          "JWT_SECRET=change-me-in-production",
          "FRONTEND_ORIGIN=http://localhost:3000",
          "CORS_ALLOWED_ORIGINS=",
          "RESEND_API_KEY=",
          "RESEND_FROM_EMAIL=noreply@multica.ai",
          "GOOGLE_CLIENT_ID=",
          "GOOGLE_CLIENT_SECRET=",
          "GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback",
          "S3_BUCKET=",
          "S3_REGION=us-west-2",
          "CLOUDFRONT_DOMAIN=",
          "CLOUDFRONT_KEY_PAIR_ID=",
          "CLOUDFRONT_PRIVATE_KEY=",
          "COOKIE_DOMAIN=",
          "MULTICA_APP_URL=http://localhost:3000"
        ],
        "depends_on": [
          "postgres"
        ]
      },
      "frontend": {
        "image": "registry.lazycat.cloud/placeholder/multica:frontend",
        "environment": [
          "HOSTNAME=0.0.0.0"
        ],
        "depends_on": [
          "backend"
        ]
      }
    },
    "application": {
      "subdomain": "multica",
      "public_path": [
        "/"
      ],
      "upstreams": [
        {
          "location": "/api/",
          "backend": "http://backend:8080/"
        },
        {
          "location": "/",
          "backend": "http://frontend:3000/"
        }
      ]
    },
