NLICENSED\nhomepage: https://github.com/CodeMasters999/PressYard\nauthor: CodeMasters999\napplication:\n  subdomain: pressyard\n  upstreams:\n    - location: /\n      backend: http://wordpress:80/\n  injects:\n    - builtin://simple-inject-password\nlocales:\n  en:\n    name: PressYard\n    description: Local WordPress development environment with isolated containers, automatic installs, and project-based hostnames.\n  zh:\n    name: PressYard\n    description: 使用隔离容器创建本地 WordPress 开发环境，支持自动安装与基于项目的主机名管理。\nservices:\n  wordpress:\n    image: registry.lazycat.cloud/codemasters999/pressyard:wordpress\n    depends_on:\n      - db\n    environment:\n      - WORDPRESS_DB_HOST=db:3306\n      - WORDPRESS_DB_USER=wordpress\n      - 'WORDPRESS_DB_PASSWORD={{ index .U \"db_password\" }}'\n      - WORDPRESS_DB_NAME=wordpress\n    binds:\n      - /lzcapp/var/data/pressyard/wp-content:/var/www/html/wp-content\n    healthcheck:\n      test:\n        - CMD-SHELL\n        - curl -fs http://127.0.0.1:80/ >/dev/null || exit 1\n      interval: 30s\n      timeout: 10s\n      retries: 5\n  db:\n    image: registry.lazycat.cloud/codemasters999/pressyard:db\n    environment:\n      - MYSQL_DATABASE=wordpress\n      - MYSQL_USER=wordpress\n      - 'MYSQL_PASSWORD={{ index .U \"db_password\" }}'\n      - 'MYSQL_ROOT_PASSWORD={{ index .U \"db_root_password\" }}'\n    binds:\n      - /lzcapp/var/db/pressyard/mysql:/var/lib/mysql\n    healthcheck:\n      test:\n        - CMD-SHELL\n        - mysqladmin ping -h 127.0.0.1 -u root -p$$MYSQL_ROOT_PASSWORD --silent\n      interval: 10s\n      timeout: 5s\n      retries: 10\n","numLines":58,"startLine":1,"totalLines":58}}}
