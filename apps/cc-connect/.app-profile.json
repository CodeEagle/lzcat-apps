{
  "managed_by": "full_migrate",
  "generated_from_upstream": "chenhg5/cc-connect",
  "fixes": {
    "project_name": "cc-connect",
    "description": "Bridge local AI coding agents to messaging platforms with a built-in web admin dashboard.",
    "description_zh": "通过内置 Web 管理台把 Claude Code、Codex、Gemini CLI 等本地 Agent 接入聊天平台。",
    "homepage": "https://github.com/chenhg5/cc-connect",
    "author": "chenhg5",
    "license": "MIT",
    "package": "fun.selfstudio.app.migration.cc-connect",
    "check_strategy": "github_release",
    "build_strategy": "target_repo_dockerfile",
    "dockerfile_type": "custom",
    "dockerfile_path": "Dockerfile",
    "build_context": ".",
    "image_targets": [
      "cc-connect"
    ],
    "service_port": 9820,
    "services": {
      "cc-connect": {
        "binds": [
          "/lzcapp/var/data/cc-connect:/data"
        ],
        "environment": [
          "CC_CONNECT_DATA_DIR=/data",
          "CC_CONNECT_CONFIG=/data/config.toml",
          "HOME=/data/home",
          "CODEX_HOME=/data/home/.codex",
          "XDG_CONFIG_HOME=/data/home/.config",
          "XDG_DATA_HOME=/data/home/.local/share",
          "XDG_CACHE_HOME=/data/home/.cache"
        ],
        "image": "registry.lazycat.cloud/placeholder/cc-connect:bootstrap"
      }
    },
    "application": {
      "subdomain": "cc-connect",
      "public_path": [
        "/"
      ],
      "upstreams": [
        {
          "location": "/",
          "backend": "http://cc-connect:9820/"
        },
        {
          "location": "/hook",
          "backend": "http://cc-connect:9111/"
        }
      ]
    },
    "startup_notes": [
      "Go 1.25 source build with embedded web admin UI.",
      "Default config is created at /data/config.toml on first start.",
      "Management-only startup is enabled by a LazyCat build patch.",
      "Agent CLI home is persisted under /data/home, with CODEX_HOME=/data/home/.codex."
    ],
    "include_content": false
  }
}
