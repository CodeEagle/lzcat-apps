{
  "build_strategy": "upstream_dockerfile",
  "check_strategy": "github_release",
  "dependencies": [
    {
      "target_service": "multica-postgres",
      "source_image": "pgvector/pgvector:pg17"
    }
  ],
  "docker_platform": "linux/amd64",
  "dockerfile_type": "custom",
  "enabled": true,
  "image_targets": [
    "multica-backend",
    "multica-frontend"
  ],
  "official_image_registry": "",
  "precompiled_binary_url": "",
  "publish_to_store": false,
  "service_builds": [
    {
      "build_args": {},
      "build_context": ".",
      "build_strategy": "upstream_dockerfile",
      "dockerfile_path": "Dockerfile",
      "image_name": "multica-multica-backend",
      "target_service": "multica-backend"
    },
    {
      "build_args": {
        "REMOTE_API_URL": "http://multica-backend:8080"
      },
      "build_context": ".",
      "build_strategy": "upstream_dockerfile",
      "dockerfile_path": "Dockerfile.web",
      "image_name": "multica-multica-frontend",
      "target_service": "multica-frontend"
    }
  ],
  "service_cmd": [],
  "service_port": 3000,
  "upstream_repo": "CodeEagle/multica"
}
