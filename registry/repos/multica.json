{
  "enabled": true,
  "upstream_repo": "multica-ai/multica",
  "check_strategy": "github_release",
  "build_strategy": "official_image",
  "publish_to_store": false,
  "official_image_registry": "ghcr.io/multica-ai/multica-backend",
  "precompiled_binary_url": "",
  "dockerfile_type": "custom",
  "service_port": 3000,
  "service_cmd": [],
  "image_targets": [
    "frontend",
    "backend"
  ],
  "dependencies": [
    {
      "target_service": "postgres",
      "source_image": "pgvector/pgvector:pg17"
    },
    {
      "target_service": "frontend",
      "source_image": "ghcr.io/multica-ai/multica-frontend:$BUILD_VERSION"
    }
  ],
  "service_builds": [],
  "docker_platform": "linux/amd64",
  "build_args": {
    "REMOTE_API_URL": "http://backend:8080"
  }
}
