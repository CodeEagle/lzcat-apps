{
  "enabled": true,
  "upstream_repo": "chaitin/PandaWiki",
  "check_strategy": "github_release",
  "build_strategy": "target_repo_dockerfile",
  "image_name": "pandawiki-lzcat",
  "publish_to_store": false,
  "official_image_registry": "",
  "precompiled_binary_url": "",
  "dockerfile_type": "custom",
  "dockerfile_path": "Dockerfile",
  "build_context": ".",
  "service_port": 8000,
  "service_cmd": [],
  "image_targets": [
    "panda-wiki-api"
  ],
  "dependencies": [
    {
      "target_service": "panda-wiki-nginx",
      "source_image": "chaitin-registry.cn-hangzhou.cr.aliyuncs.com/chaitin/panda-wiki-nginx:$SOURCE_VERSION"
    },
    {
      "target_service": "panda-wiki-postgres",
      "source_image": "chaitin-registry.cn-hangzhou.cr.aliyuncs.com/chaitin/postgres-zhparser:17.6-bookworm"
    },
    {
      "target_service": "panda-wiki-redis",
      "source_image": "chaitin-registry.cn-hangzhou.cr.aliyuncs.com/chaitin/panda-wiki-redis:7.4.2-alpine"
    },
    {
      "target_service": "panda-wiki-minio",
      "source_image": "chaitin-registry.cn-hangzhou.cr.aliyuncs.com/chaitin/panda-wiki-minio:RELEASE.2025-04-22T22-12-26Z-cpuv1"
    }
  ]
}
