{
  "enabled": true,
  "upstream_repo": "openops-cloud/openops",
  "check_strategy": "github_release",
  "build_strategy": "official_image",
  "publish_to_store": false,
  "official_image_registry": "public.ecr.aws/openops/openops-app",
  "precompiled_binary_url": "",
  "dockerfile_type": "custom",
  "service_port": 80,
  "service_cmd": [],
  "image_targets": [
    "openops-app"
  ],
  "dependencies": [
    {
      "target_service": "openops-engine",
      "source_image": "public.ecr.aws/openops/openops-engine:$SOURCE_VERSION"
    },
    {
      "target_service": "openops-tables",
      "source_image": "public.ecr.aws/openops/openops-tables:0.2.17"
    },
    {
      "target_service": "openops-analytics",
      "source_image": "public.ecr.aws/openops/openops-analytics:0.14.6"
    },
    {
      "target_service": "postgres",
      "source_image": "postgres:14.4"
    },
    {
      "target_service": "redis",
      "source_image": "redis:7.4.0"
    }
  ]
}
